# Configuration template for RTL Hardware Development Project
# Copy this file to .env and customize with your local paths
# DO NOT commit .env to version control (add to .gitignore)

# Sky130 PDK Library Path (Required for specific synthesis)
# Example: /home/username/pdk/volare/sky130/versions/.../sky130_fd_sc_hd__tt_100C_1v80.lib
SKY130_LIB_PATH=

# Optional: Alternative library paths
# SKY130_LIB_PATH_FAST=
# SKY130_LIB_PATH_SLOW=

# Yosys executable (defaults to 'yosys' in PATH)
# YOSYS_BIN=yosys

# Netlistsvg executable (defaults to 'netlistsvg' in PATH)
# NETLISTSVG_BIN=netlistsvg
